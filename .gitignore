# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
*.tsbuildinfo

# Environment
.env
.env.*
!.env.example

# Local data / runtime — ignore any `data/` dir by default (they may hold client
# PII, e.g. apps/dashboard/src/data/brokers.seed.json). Exception: the build-time
# JSON fixtures under packages/shared/src, which must ship with the repo.
data/
!packages/shared/src/**/data/
!packages/shared/src/**/data/**
*.local
*.log

# Client scope allowlist (contains client PII) — keep only the example
tools/kb-compliance/config/client-allowlist.json

# SharePoint backfill mapping (broker → existing folder path; client PII)
tools/kb-compliance/config/sharepoint-mapping.json

# Notion action-plan snapshot (broker names + follow-up notes; client PII)
apps/dashboard/scripts/notion-plan-snapshot.json

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Observer tooling locks
.observer.lock
**/.observer.lock

# Local client data (leads, prospects — PII, never commit)
local-data/
.n8n-secrets.deploy.txt
