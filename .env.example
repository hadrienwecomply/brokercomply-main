DATABASE_URL=postgresql://brokercomply:brokercomply@localhost:5432/brokercomply
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Action-plan template emails are sent FROM the broker's assigned officer mailbox
# (no shared mailbox). Only the AZURE_* app-only credentials above are needed;
# per-officer send-as is granted by an Exchange Application Access Policy.
# Safety guard: redirect ALL outgoing emails here until go-live (real recipients
# are shown in the body). Outside production this defaults to hr@we-comply.be
# even if left blank. Leave empty in production for real delivery.
MAIL_REDIRECT_TO=hr@we-comply.be

# SharePoint document sync (broker folders). Reuses the AZURE_* app + a per-site
# `Sites.Selected` write grant. SHAREPOINT_SITE_ID is the Graph site id
# "host.sharepoint.com,<siteGuid>,<webGuid>"; SHAREPOINT_ROOT_PATH is the
# drive-relative folder under which every broker folder is created.
SHAREPOINT_SITE_ID=
SHAREPOINT_ROOT_PATH=01 - Verticales/01 - Brokercomply/01 - Clients & Prospects/01 - Clients

LLM_PROVIDER=anthropic          # anthropic | openai
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
EMBEDDING_API_KEY=               # OpenAI key pour embeddings
EMBEDDING_MODEL=text-embedding-3-small
FRESHNESS_THRESHOLD_MONTHS=12

# Fillout form ingestion (inbound webhook). Both required to accept calls:
# token in the URL path  → /api/webhooks/fillout/<FILLOUT_URL_TOKEN>
# shared-secret header   → X-Webhook-Secret: <FILLOUT_WEBHOOK_SECRET>
FILLOUT_URL_TOKEN=               # long random string, part of the webhook URL
FILLOUT_WEBHOOK_SECRET=          # long random string, set as a Fillout webhook header

# n8n trigger (outbound). Default workflow URL + shared secret sent as a header.
# Per-form URLs can override N8N_WEBHOOK_URL via apps/dashboard/src/lib/form-template.ts
N8N_WEBHOOK_URL=                 # e.g. https://n8n.example.com/webhook/brokercomply
N8N_WEBHOOK_SECRET=              # validated by the n8n Webhook node (Header Auth)

# n8n result callback (inbound, mirror of the Fillout webhook). The workflow's
# final HTTP Request node POSTs the result back to:
#   /api/webhooks/n8n/<N8N_CALLBACK_TOKEN>  with header  X-Callback-Secret: <N8N_CALLBACK_SECRET>
N8N_CALLBACK_TOKEN=              # long random string, part of the callback URL
N8N_CALLBACK_SECRET=             # long random string, set as the n8n HTTP Request header

# n8n PDF workflow — triggered by the "Générer le PDF" button on a review.
N8N_PDF_WEBHOOK_URL=             # e.g. https://n8n.example.com/webhook/rapport-review

# n8n branded-report workflow for website compliance audits.
N8N_RAPPORT_WEBHOOK_URL=         # e.g. https://n8n.example.com/webhook/rapport-reco
# n8n branded-report workflow for print-advertising audits (falls back to
# N8N_RAPPORT_WEBHOOK_URL when unset).
N8N_PUB_RAPPORT_WEBHOOK_URL=     # e.g. https://n8n.example.com/webhook/rapport-pub
