DATABASE_URL=postgresql://brokercomply:brokercomply@localhost:5432/brokercomply
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# SharePoint document sync (broker folders). Reuses the AZURE_* app + a per-site
# `Sites.Selected` write grant. SHAREPOINT_SITE_ID is the Graph site id
# "host.sharepoint.com,<siteGuid>,<webGuid>"; SHAREPOINT_ROOT_PATH is the
# drive-relative folder under which every broker folder is created.
SHAREPOINT_SITE_ID=
SHAREPOINT_ROOT_PATH=01 - Verticales/01 - Brokercomply/01 - Clients & Prospects/01 - Clients

LLM_PROVIDER=anthropic          # anthropic | openai
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
EMBEDDING_API_KEY=               # OpenAI key pour embeddings
EMBEDDING_MODEL=text-embedding-3-small
FRESHNESS_THRESHOLD_MONTHS=12
