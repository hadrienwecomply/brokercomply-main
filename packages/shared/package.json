    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@azure/identity": "^4.13.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "dotenv": "^16.4.0",
    "drizzle-orm": "~0.39.0",
    "openai": "^6.42.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  }
